{
  "name": "@eser/stack",
  "version": "4.1.3",
  "private": true,
  "type": "module",
  "workspaces": [
    "pkg/@eser/*",
    "pkg/@cool/*"
  ],
  "scripts": {
    "check:mod": "deno check ./pkg/@eser/*/mod.ts ./pkg/@cool/*/mod.ts",
    "cleanup": "rm -rf ./etc/coverage/* ./etc/coverage.lcov ./deno.lock && deno task check:mod",
    "cli": "deno run --allow-all ./pkg/@eser/cli/main.ts",
    "container:build": "docker build -t eservm .",
    "container:run": "docker run --interactive --tty --rm eservm",
    "doc:generate": "rm -rf ./docs/ && deno doc --name='eserstack' --output=./docs/ --html ./pkg/@eser/*/mod.ts ./pkg/@cool/*/mod.ts",
    "doc:lint": "deno doc --lint ./pkg/@eser/*/mod.ts ./pkg/@cool/*/mod.ts",
    "npm-build": "deno run --allow-all ./pkg/@eser/cli/scripts/npm-build.ts",
    "repl": "deno repl --allow-all --unstable-bundle --eval-file=./repl-init.ts",
    "test:coverage-gen": "deno coverage ./etc/coverage --lcov --output=./etc/coverage.lcov",
    "test:coverage": "deno coverage ./etc/coverage/",
    "test:run": "deno test --allow-sys --allow-net --allow-env --allow-read --allow-write --allow-run --allow-ffi --parallel --trace-leaks --coverage=./etc/coverage/",
    "test": "deno test --allow-sys --allow-net --allow-env --allow-read --allow-write --allow-run --allow-ffi --parallel --watch",
    "validate:fix": "deno fmt && deno lint --fix && deno task cli codebase validate --only licenses --fix && deno task check:mod && deno task test:run && deno publish --dry-run --allow-dirty",
    "validate": "deno fmt --check && deno lint && deno task cli codebase validate --only licenses && deno task check:mod && deno task test:run && deno publish --dry-run --allow-dirty",
    "version:bump-patch": "deno run --allow-all ./pkg/@eser/codebase/versions.ts patch",
    "version:bump-minor": "deno run --allow-all ./pkg/@eser/codebase/versions.ts minor",
    "version:bump-major": "deno run --allow-all ./pkg/@eser/codebase/versions.ts major"
  }
}
