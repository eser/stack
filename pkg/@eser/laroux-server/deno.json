{
  "name": "@eser/laroux-server",
  "version": "4.0.20",
  "imports": {
    "@std/assert": "jsr:@std/assert@^1.0.16",
    "@std/cli": "jsr:@std/cli@^1.0.25",
    "@std/media-types": "jsr:@std/media-types@^1.1.0",
    "react": "npm:react@^19.1.0",
    "react/jsx-runtime": "npm:react@^19.1.0/jsx-runtime",
    "react-dom/server": "npm:react-dom@^19.1.0/server"
  },
  "exports": {
    ".": "./main.ts",
    "./config": "./config/load-config.ts",
    "./adapters/react": "./adapters/react/mod.ts"
  },
  "publish": {
    "include": [
      "main.ts",
      "options.ts",
      "domain/**/*.ts",
      "adapters/**/*.ts",
      "adapters/**/*.tsx",
      "runtime/**/*.ts",
      "config/**/*.ts",
      "proxy/**/*.ts",
      "error-formatting.ts",
      "product-info.ts",
      "README.md",
      "LICENSE"
    ]
  }
}
