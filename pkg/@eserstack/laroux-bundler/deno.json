{
  "name": "@eserstack/laroux-bundler",
  "version": "4.1.56",
  "exports": {
    ".": "./mod.ts",
    "./adapters": "./adapters/mod.ts",
    "./adapters/react": "./adapters/react/mod.ts",
    "./adapters/tailwindcss": "./adapters/tailwindcss/mod.ts",
    "./adapters/lightningcss": "./adapters/lightningcss/mod.ts",
    "./adapters/sharp": "./adapters/sharp/mod.ts",
    "./adapters/fonts": "./adapters/fonts/mod.ts",
    "./adapters/runtime-bundler": "./adapters/runtime-bundler/mod.ts",
    "./adapters/prebuilt-bundler": "./adapters/prebuilt-bundler/mod.ts",
    "./system": "./system.ts",
    "./config": "./config.ts",
    "./types": "./types.ts"
  },
  "publish": {
    "include": [
      "mod.ts",
      "system.ts",
      "config.ts",
      "types.ts",
      "css-modules.ts",
      "jsr-resolver-plugin.ts",
      "import-map-resolver-plugin.ts",
      "server-externals-plugin.ts",
      "domain/**/*.ts",
      "adapters/**/*.ts",
      "README.md",
      "LICENSE"
    ]
  }
}
