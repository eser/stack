{
  "name": "@eserstack/posts",
  "version": "4.1.56",
  "exports": {
    ".": "./mod.ts",
    "./domain": "./domain/mod.ts",
    "./application": "./application/mod.ts",
    "./testing": "./application/testing.ts",
    "./module": "./module.ts",
    "./go-posts": "./go-posts.ts"
  },
  "tasks": {
    "tui": "deno run --allow-net --allow-env --allow-read --allow-write adapters/tui/app.ts",
